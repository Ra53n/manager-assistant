{
  "name": "manager-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Сервис-агент рутин для Manager assistant: планировщик (cron) 24/7, выполнение промптов через LLM (DeepSeek) с инструментами YouGile MCP, агрегация и сохранение результата (VPS/YouGile), REST API для приложения.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --watch --import tsx/esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.0",
    "croner": "^8.1.2",
    "fastify": "^4.28.1",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
