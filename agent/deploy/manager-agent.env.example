# Bootstrap-конфигурация агента рутин. На VPS лежит в /etc/manager-agent.env
# (НЕ в git, режим 0640, владелец root:manageragent).
#
# Здесь — ТОЛЬКО bootstrap. LLM-провайдер/ключ, модель и доступ к YouGile MCP
# задаются ИЗ ПРИЛОЖЕНИЯ (экран «Настройки агента» → PUT /agent/settings) и
# хранятся в БД, а не здесь.

# Bearer-токен, который приложение предъявляет API. Сгенерируй свой:
#   openssl rand -hex 32
# Этот же токен вводится в приложении (Подключение к VPS → токен доступа).
AGENT_API_TOKEN=replace-with-strong-random-token

# HTTP-сервер агента. Наружу не открывается — только loopback за Caddy.
AGENT_HOST=127.0.0.1
AGENT_PORT=3100

# SQLite с рутинами и прогонами. Переживает деплой; deploy.sh его НЕ трогает.
AGENT_DB_PATH=/opt/manager-agent/data/agent.db

# Дефолтная таймзона расписаний (на рутину можно переопределить в приложении).
AGENT_DEFAULT_TZ=Europe/Moscow

LOG_LEVEL=info
